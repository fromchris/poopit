// Loopit — prod-ready schema.
// Runs on SQLite locally; swap to PostgreSQL by changing provider + url.
// All fields that would benefit from FTS/vector are annotated — Postgres
// migrations add those indexes.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── USERS / AUTH ────────────────────────────
model User {
  id           String   @id @default(cuid())
  handle       String   @unique                   // e.g. "@you.loop" (unique, case-insensitive via app-level lower())
  handleLower  String   @unique                   // for case-insensitive lookup
  email        String?  @unique
  passwordHash String?                            // null for anonymous/guest accounts
  bio          String   @default("")
  avatar       String   @default("🦄")            // emoji for now; later: URL to object storage
  isGuest      Boolean  @default(false)           // true until user sets password
  recoveryCode String?                            // one-shot recovery code for guest accounts
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  sessions        Session[]
  playables       Playable[]     @relation("creator")
  likes           Like[]
  comments        Comment[]
  commentLikes    CommentLike[]
  followedBy      Follow[]       @relation("followee")
  following       Follow[]       @relation("follower")
  notifications   Notification[] @relation("recipient")
  actorEvents     Notification[] @relation("actor")
  generationJobs  GenerationJob[]
  conversations   ConversationMember[]
  sentMessages    Message[]      @relation("sender")

  @@index([createdAt])
}

// ───────────────────────────── DM ─────────────────────────────
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastMessageAt DateTime @default(now())
  members   ConversationMember[]
  messages  Message[]

  @@index([lastMessageAt])
}

model ConversationMember {
  conversationId String
  userId         String
  lastReadAt     DateTime?
  role           String   @default("member") // "member" | "admin" (future: groups)
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  /// Optional playable shared in chat
  playableId     String?
  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique                     // sha256 of the cookie value; never store raw
  csrfToken  String                               // double-submit token
  userAgent  String?
  ipHash     String?                              // hashed IP (privacy)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────────── PLAYABLES ─────────────────────────────
model Playable {
  id          String         @id @default(cuid())
  creatorId   String
  kind        String                                // "bubble-pop" | "squishy-blob" | "rhythm-tap" | "color-splat" | "fidget-spinner" | "interactive-drama"
  title       String
  description String
  theme       String                                // tailwind gradient classes (e.g. "from-cyan-400 via-sky-500 to-indigo-600")
  params      String         @default("{}")         // JSON: mechanic-specific parameters (LLM-generated or template)
  bundleUrl   String?                               // for interactive-drama / code-mode: URL to HTML bundle
  thumbnailUrl String?                              // first-frame thumbnail (generated by worker)
  sourceId    String?                               // if this is a remix
  visibility  String         @default("public")     // "public" | "unlisted" | "draft" | "deleted"
  trendingScore Float        @default(0)            // periodic recompute job populates this
  likeCount   Int            @default(0)            // denormalized counters for O(1) reads
  commentCount Int           @default(0)
  remixCount  Int            @default(0)
  playCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  creator  User        @relation("creator", fields: [creatorId], references: [id], onDelete: Cascade)
  source   Playable?   @relation("remixSource", fields: [sourceId], references: [id], onDelete: SetNull)
  remixes  Playable[]  @relation("remixSource")
  tags     PlayableTag[]
  likes    Like[]
  comments Comment[]
  plays    PlayEvent[]
  reports  Report[]

  @@index([creatorId, createdAt])
  @@index([visibility, trendingScore])
  @@index([visibility, createdAt])
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  uses  Int           @default(0)
  playables PlayableTag[]

  @@index([uses])
}

model PlayableTag {
  playableId String
  tagId      String
  playable   Playable @relation(fields: [playableId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([playableId, tagId])
  @@index([tagId])
}

// ───────────────────────── ENGAGEMENT ─────────────────────────
model Like {
  userId     String
  playableId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playable Playable @relation(fields: [playableId], references: [id], onDelete: Cascade)

  @@id([userId, playableId])
  @@index([playableId, createdAt])
}

model Follow {
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
}

model Comment {
  id         String   @id @default(cuid())
  playableId String
  authorId   String
  parentId   String?                      // for threaded replies
  body       String
  likeCount  Int      @default(0)
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  playable Playable      @relation(fields: [playableId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?      @relation("commentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]     @relation("commentThread")
  likes    CommentLike[]

  @@index([playableId, createdAt])
  @@index([authorId, createdAt])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

// ───────────────────────── ANALYTICS ─────────────────────────
model PlayEvent {
  id         String   @id @default(cuid())
  playableId String
  userId     String?                               // null for anonymous
  sessionKey String                                // for dedup (userId || cookie || ip+ua hash)
  completed  Boolean  @default(false)
  duration   Int      @default(0)                  // seconds
  createdAt  DateTime @default(now())

  playable Playable @relation(fields: [playableId], references: [id], onDelete: Cascade)

  @@index([playableId, createdAt])
  @@index([sessionKey, playableId])
}

// ───────────────────────── NOTIFICATIONS ─────────────────────────
model Notification {
  id          String   @id @default(cuid())
  recipientId String
  actorId     String?
  type        String                                  // "like" | "comment" | "follow" | "remix" | "system"
  targetId    String?                                 // playable/comment id
  targetTitle String?                                 // denormalized for fast list render
  preview     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient User  @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, read, createdAt])
}

// ───────────────────────── MODERATION ─────────────────────────
model Report {
  id         String   @id @default(cuid())
  reporterId String?
  playableId String?
  commentId  String?
  reason     String
  notes      String?
  status     String   @default("pending")             // "pending" | "actioned" | "dismissed"
  createdAt  DateTime @default(now())

  playable Playable? @relation(fields: [playableId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model BlockedUser {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
}

// ───────────────────────── LLM JOBS ─────────────────────────
model GenerationJob {
  id         String   @id @default(cuid())
  userId     String
  prompt     String
  sourceId   String?                                  // for remix
  mode       String   @default("parameter")           // "parameter" | "code"
  status     String   @default("queued")              // "queued" | "running" | "succeeded" | "failed" | "rejected"
  playableId String?                                  // result
  errorCode  String?
  steps      String   @default("[]")                  // JSON array of progress events
  promptTokens Int    @default(0)
  outputTokens Int    @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ───────────────────────── RATE LIMIT / AUDIT ─────────────────────────
model RateLimitBucket {
  key       String   @id                        // "ip:1.2.3.4:like" or "user:abc:generate"
  tokens    Float
  updatedAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String                               // "login" | "publish" | "delete" | "moderate"
  target    String?
  meta      String   @default("{}")              // JSON
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
