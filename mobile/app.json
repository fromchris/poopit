{
  "expo": {
    "name": "Loopit",
    "slug": "loopit",
    "owner": "ccczzz",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "loopit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.loopit.client",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [],
        "NSCameraUsageDescription": "Loopit lets you attach photos and videos when creating a playable.",
        "NSPhotoLibraryUsageDescription": "Loopit lets you attach photos and videos when creating a playable.",
        "NSMicrophoneUsageDescription": "Loopit records audio when you attach a video clip."
      }
    },
    "android": {
      "package": "app.loopit.client",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": []
  }
}
