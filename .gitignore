# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# app runtime data (uploads, generated bundles, debug dumps)
/storage

# build artifact we don't track
/loopit-prototype.zip
/dist

# dev SQLite (schema is in prisma/schema.prisma; data is ephemeral)
/prisma/**/*.db
/prisma/**/*.db-journal

# Capacitor native build outputs (ios/ + android/ scaffolds are tracked
# once generated, but their build/ + Pods/ + .gradle/ + DerivedData are not)
/ios/App/build/
/ios/App/Pods/
/ios/App/Podfile.lock
/ios/DerivedData/
/ios/.DS_Store
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/app/release/
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/capacitor.plugins.json
/android/app/src/main/assets/public/
