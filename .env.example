# ── Required ─────────────────────────────────────────────
# SQLite for local dev. In production, use PostgreSQL:
#   DATABASE_URL="postgresql://user:pass@host:5432/loopit?schema=public"
DATABASE_URL="file:./prisma/loopit.db"

# Used to sign session cookies and hash session tokens.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-48-byte-base64url-secret"

# ── LLM (optional) ───────────────────────────────────────
# Without a key, /api/generate falls back to a local deterministic
# synth (picks a mechanic + theme based on prompt keywords).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4"
# Point at a custom gateway (Azure / OpenRouter / self-hosted proxy).
# Leave unset for api.openai.com.
# OPENAI_BASE_URL="http://your-gateway:8080/v1"
# One of: minimal | low | medium | high | xhigh (custom gateways).
OPENAI_REASONING_EFFORT="high"

# ── Storage (optional) ───────────────────────────────────
# "fs" writes to ./storage/ (default). "s3" uses env vars below.
STORAGE_DRIVER="fs"
# S3_ENDPOINT=""
# S3_REGION="us-east-1"
# S3_BUCKET="loopit-assets"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_BASE_URL="https://cdn.example.com"

# ── Ops ──────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="info"
PORT="3000"

# Rate limits (per-window token buckets)
RATE_LIMIT_GENERATE_PER_HOUR="10"
RATE_LIMIT_COMMENT_PER_MINUTE="6"
RATE_LIMIT_LIKE_PER_MINUTE="120"
